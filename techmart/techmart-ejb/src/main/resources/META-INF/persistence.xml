<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">

    <persistence-unit name="TechmartPU" transaction-type="JTA">

        <jta-data-source>jdbc/TechmartDB</jta-data-source>

        <class>lk.sithikaDev.techmart.entity.Users</class>
        <class>lk.sithikaDev.techmart.entity.Product</class>
        <class>lk.sithikaDev.techmart.entity.Notification</class>
        <class>lk.sithikaDev.techmart.entity.Order</class>
        <class>lk.sithikaDev.techmart.entity.CartItem</class>
        <class>lk.sithikaDev.techmart.entity.Payment</class>

        <properties>
            <property name="jakarta.persistence.schema-generation.database.action"
                      value="create"/>
        </properties>

    </persistence-unit>

</persistence>